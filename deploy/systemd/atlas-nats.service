[Unit]
Description=Atlas NATS JetStream (Global Workspace / Event Fabric)
After=network.target
Documentation=Baars (1988): Global Workspace Theory — shared broadcast medium

[Service]
Type=simple
User=claude
ExecStart=/usr/local/bin/nats-server \
    --jetstream \
    --store_dir /home/claude/nats-data \
    --addr 0.0.0.0 --port 4222 \
    --http_port 8222 \
    --max_payload 1048576
Restart=always
RestartSec=5
StartLimitIntervalSec=60
StartLimitBurst=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=atlas.target
