# Atlas JupyterHub — environment template
# Copy this file to `.env` and fill in your values.
# `.env` is gitignored; never commit it.

# ---- Public-facing domain ------------------------------------------------
# The DNS name that your students type into their browser.
# Must resolve to your Comcast public IP.
DOMAIN=jupyter.example.com

# ---- GitHub OAuth --------------------------------------------------------
# Create an app at https://github.com/settings/developers
# Homepage: https://<DOMAIN>/
# Callback: https://<DOMAIN>/hub/oauth_callback
GITHUB_CLIENT_ID=paste_your_oauth_client_id_here
GITHUB_CLIENT_SECRET=paste_your_oauth_client_secret_here
OAUTH_CALLBACK_URL=https://jupyter.example.com/hub/oauth_callback

# ---- Resource caps per user ---------------------------------------------
# CPU is a soft cap (docker cgroups).
USER_CPU_LIMIT=2.0
# Memory is hard-killed at this ceiling.
USER_MEM_LIMIT=8G
# Idle sessions are culled after this many seconds (default: 1 hour).
IDLE_CULL_SECONDS=3600
